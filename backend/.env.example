# Copy to .env and fill in real values. Never commit the real .env file.

# Postgres connection (local docker-compose or Supabase connection string)
DATABASE_URL="postgresql://virata:virata_dev_password@localhost:5432/virata_hr?schema=public"

PORT=3000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES="7d"

# Seed admin user (created by prisma/seed.ts on first run)
SEED_ADMIN_EMAIL="admin@virata-hr.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Attendance / geo-fencing
# If true, check-in outside every configured geo-fence location is rejected.
# If false, it is recorded but flagged withinGeofence=false.
ENFORCE_GEOFENCE=true
